# Runtime artifacts produced by skills
**/__pycache__/
*.pyc
skills/weekly-report/output/

# Secrets that skills may generate at runtime (never commit these)
**/google_token.json
**/client_secret_*.json
**/credentials.json
**/token.json
**/tokens/
*.pem
*.key

# Tool-specific symlinks created by setup.sh (point at ../skills)
/.claude/skills
/.opencode/skills
/.agents/skills
/.cursor/commands

# Generated Cursor commands (regenerated by scripts/build-cursor.sh)
/dist/
